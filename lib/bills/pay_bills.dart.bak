  Widget _buildCableForm() {
    return Column(
      crossAxisAlignment: CrossAxisAlignment.start,
      children: [
        const Text(
          "Buy Cable",
          style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
        ),
        const SizedBox(height: 20),
        const Text(
          "Select Operator",
          style: TextStyle(fontWeight: FontWeight.w600, color: Colors.black54),
        ),
        const SizedBox(height: 4),
        isFetchingCableBillers
            ? Center(child: CircularProgressIndicator(color: primaryColor))
            : DropdownSearch<String>(
                popupProps: PopupProps.menu(
                  menuProps: MenuProps(
                    backgroundColor: Colors.white, // popup background color
                  ),
                  showSearchBox: true,
                  searchFieldProps: TextFieldProps(
                    decoration: InputDecoration(
                      hintText: "Search operator...",
                      border: OutlineInputBorder(
                        borderRadius: BorderRadius.circular(8),
                      ),
                      contentPadding: EdgeInsets.symmetric(
                        horizontal: 16,
                        vertical: 12,
                      ),
                    ),
                  ),
                ),
                items: (filter, loadProps) => cableBillers
                    .where(
                      (biller) =>
                          ((biller['attributes']['name'] as String?) ?? '')
                              .toLowerCase()
                              .contains(filter.toLowerCase()),
                    )
                    .map((biller) => biller['id'] as String)
                    .toList(),
                decoratorProps: DropDownDecoratorProps(
                  decoration: InputDecoration(
                    border: OutlineInputBorder(
                      borderRadius: BorderRadius.circular(8),
                    ),
                    contentPadding: const EdgeInsets.symmetric(
                      horizontal: 16,
                      vertical: 16,
                    ),
                  ),
                ),
                selectedItem: selectedCableOperator,
                itemAsString: (String? identifier) {
                  final biller = cableBillers.firstWhere(
                    (b) => b['id'] == identifier,
                    orElse: () => {
                      'attributes': {'name': 'Unknown'},
                    },
                  );
                  return (biller['attributes']['name'] as String?) ?? 'Unknown';
                },
                onChanged: (v) {
                  setState(() {
                    selectedCableOperator = v;
                    selectedCablePackage = null;
                    cableAmountController.text = '';
                  });
                  if (v != null) _fetchProducts(v, 'television');
                },
                dropdownBuilder: (context, selectedItem) {
                  if (selectedItem == null) {
                    return Text(
                      'Select an operator',
                      style: TextStyle(
                        fontSize: 15,
                        color: Colors.grey.shade500,
                      ),
                    );
                  }
                  final biller = cableBillers.firstWhere(
                    (b) => b['id'] == selectedItem,
                    orElse: () => {
                      'attributes': {'name': 'Unknown'},
                      'id': '',
                    },
                  );
                  return Row(
                    children: [
                      // CircleAvatar(
                      //   radius: 10,
                      //   backgroundImage: NetworkImage(
                      //     _getCableLogo(biller['id'] as String),
                      //   ),
