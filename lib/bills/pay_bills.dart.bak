                    orElse: () => {
                      'attributes': {
                        'name': 'N/A',
                        'price': {'minimumAmount': 0},
                      },
                    },
                  );
                  return '${(sub['attributes']['name'] as String?) ?? 'Unknown'} - ₦${((sub['attributes']['price']['minimumAmount'] as num? ?? 0) / 100).toStringAsFixed(0)}';
                },
                onChanged: (v) {
                  setState(() {
                    selectedCablePackage = v;
                    if (v != null) {
                      final selectedSub = cableSubscriptions.firstWhere(
                        (sub) => sub['attributes']['slug'] == v,
                      );
                      cableAmountController.text =
